{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floatingpragma.io/schemas/oph-edge-center-clock-v1.schema.json",
  "title": "OPH edge-center clock evidence certificate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "selected_target",
    "evidence_present",
    "tolerance",
    "tolerance_profile",
    "observed",
    "checks",
    "receipts",
    "FULL_COLLAR_DERIVATIVE_P_OVER_24_RECEIPT",
    "ORIENTATION_HALF_IDENTITY_RECEIPT",
    "SEMIGROUP_DEFECT_RECEIPT",
    "REFINEMENT_DEFECT_RECEIPT",
    "PHYSICAL_CLOCK_BINDING_RECEIPT",
    "CLOCK_BINDING_PACKET_CONSISTENCY_RECEIPT",
    "SOURCE_DAG_CLEAN_RECEIPT",
    "GENERATIVE_PIXEL_PROFILE_RECEIPT",
    "INDEPENDENT_FINITE_RUN_REPLAY_RECEIPT",
    "EDGE_CENTER_CLOCK_PACKET_CONSISTENCY_RECEIPT",
    "legacy_receipt_declarations_promoted",
    "EDGE_CENTER_CLOCK_RECEIPT",
    "edge_center_clock_evidence_complete",
    "missing_receipts",
    "finite_step_survival_exponent_is_distinct",
    "claim_boundary"
  ],
  "properties": {
    "schema": {"const": "oph-edge-center-clock-v1"},
    "selected_target": {"$ref": "#/$defs/target"},
    "evidence_present": {"type": "boolean"},
    "tolerance": {"type": "number", "minimum": 0, "maximum": 1e-6},
    "tolerance_profile": {"$ref": "#/$defs/toleranceProfile"},
    "observed": {"$ref": "#/$defs/observed"},
    "checks": {"$ref": "#/$defs/checks"},
    "receipts": {"$ref": "#/$defs/receipts"},
    "FULL_COLLAR_DERIVATIVE_P_OVER_24_RECEIPT": {"type": "boolean"},
    "ORIENTATION_HALF_IDENTITY_RECEIPT": {"type": "boolean"},
    "SEMIGROUP_DEFECT_RECEIPT": {"type": "boolean"},
    "REFINEMENT_DEFECT_RECEIPT": {"type": "boolean"},
    "PHYSICAL_CLOCK_BINDING_RECEIPT": {"const": false},
    "CLOCK_BINDING_PACKET_CONSISTENCY_RECEIPT": {"type": "boolean"},
    "SOURCE_DAG_CLEAN_RECEIPT": {"type": "boolean"},
    "GENERATIVE_PIXEL_PROFILE_RECEIPT": {"type": "boolean"},
    "INDEPENDENT_FINITE_RUN_REPLAY_RECEIPT": {"const": false},
    "EDGE_CENTER_CLOCK_PACKET_CONSISTENCY_RECEIPT": {"type": "boolean"},
    "legacy_receipt_declarations_promoted": {"const": false},
    "EDGE_CENTER_CLOCK_RECEIPT": {"const": false},
    "edge_center_clock_evidence_complete": {"const": false},
    "missing_receipts": {
      "type": "array",
      "items": {"enum": [
        "FULL_COLLAR_DERIVATIVE_P_OVER_24_RECEIPT",
        "ORIENTATION_HALF_IDENTITY_RECEIPT",
        "SEMIGROUP_DEFECT_RECEIPT",
        "REFINEMENT_DEFECT_RECEIPT",
        "PHYSICAL_CLOCK_BINDING_RECEIPT",
        "SOURCE_DAG_CLEAN_RECEIPT",
        "GENERATIVE_PIXEL_PROFILE_RECEIPT",
        "INDEPENDENT_FINITE_RUN_REPLAY_RECEIPT"
      ]},
      "uniqueItems": true
    },
    "finite_step_survival_exponent_is_distinct": {"const": true},
    "claim_boundary": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "EDGE_CENTER_CLOCK_PACKET_CONSISTENCY_RECEIPT": {"const": true}
        },
        "required": ["EDGE_CENTER_CLOCK_PACKET_CONSISTENCY_RECEIPT"]
      },
      "then": {
        "properties": {
          "evidence_present": {"const": true},
          "edge_center_clock_evidence_complete": {"const": false},
          "missing_receipts": {
            "const": [
              "PHYSICAL_CLOCK_BINDING_RECEIPT",
              "INDEPENDENT_FINITE_RUN_REPLAY_RECEIPT"
            ]
          },
          "FULL_COLLAR_DERIVATIVE_P_OVER_24_RECEIPT": {"const": true},
          "ORIENTATION_HALF_IDENTITY_RECEIPT": {"const": true},
          "SEMIGROUP_DEFECT_RECEIPT": {"const": true},
          "REFINEMENT_DEFECT_RECEIPT": {"const": true},
          "PHYSICAL_CLOCK_BINDING_RECEIPT": {"const": false},
          "CLOCK_BINDING_PACKET_CONSISTENCY_RECEIPT": {"const": true},
          "SOURCE_DAG_CLEAN_RECEIPT": {"const": true},
          "GENERATIVE_PIXEL_PROFILE_RECEIPT": {"const": true},
          "checks": {
            "properties": {
              "full_collar_derivative_equals_P_over_24": {"const": true},
              "orientation_half_identity": {"const": true},
              "semigroup_defect_bounded": {"const": true},
              "refinement_defect_bounded": {"const": true},
              "clock_binding_packet_consistency": {"const": true},
              "source_dag_clean_hash_bound": {"const": true},
              "generative_pixel_profile_bound": {"const": true}
            }
          },
          "receipts": {
            "properties": {
              "FULL_COLLAR_DERIVATIVE_P_OVER_24_RECEIPT": {"const": true},
              "ORIENTATION_HALF_IDENTITY_RECEIPT": {"const": true},
              "SEMIGROUP_DEFECT_RECEIPT": {"const": true},
              "REFINEMENT_DEFECT_RECEIPT": {"const": true},
              "PHYSICAL_CLOCK_BINDING_RECEIPT": {"const": false},
              "SOURCE_DAG_CLEAN_RECEIPT": {"const": true},
              "GENERATIVE_PIXEL_PROFILE_RECEIPT": {"const": true}
            }
          },
          "observed": {
            "properties": {
              "clock_binding_hash_matches": {"const": true},
              "source_dag_hash_matches": {"const": true},
              "source_dag_audit": {
                "properties": {
                  "clean": {"const": true},
                  "binding_node_present": {"const": true},
                  "binding_node_kind_valid": {"const": true},
                  "binding_node_hash_matches": {"const": true},
                  "binding_node_is_leaf": {"const": true},
                  "root_source_reaches_binding": {"const": true},
                  "all_nodes_ancestral_to_binding": {"const": true}
                }
              },
              "pixel_provenance": {
                "required": ["GENERATIVE_PIXEL_PROFILE_RECEIPT"],
                "properties": {
                  "GENERATIVE_PIXEL_PROFILE_RECEIPT": {"const": true}
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "toleranceProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "default", "maximum"],
      "properties": {
        "profile": {"const": "oph-edge-center-clock-defect-profile-v1"},
        "default": {"const": 1e-12},
        "maximum": {"const": 1e-6}
      }
    },
    "nullableNumber": {"type": ["number", "null"]},
    "nullableDefect": {
      "anyOf": [
        {"type": "null"},
        {"type": "number", "minimum": 0, "maximum": 1e-6}
      ]
    },
    "nullableInteger": {"type": ["integer", "null"]},
    "nullableString": {"type": ["string", "null"]},
    "nullableHash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "target": {
      "type": "object",
      "required": [
        "selected_branch",
        "formula",
        "P",
        "phi",
        "delta_P",
        "full_collar_derivative_target",
        "orientation_halves",
        "theta",
        "eta_R",
        "n_s",
        "kappa_rep",
        "kappa_rep_formula",
        "selected_theorem_target",
        "finite_lattice_derived",
        "diagnostic_controls"
      ],
      "properties": {
        "selected_branch": {"const": "edge_center_orientation_half"},
        "formula": {"type": "string"},
        "P": {"type": "number"},
        "phi": {"type": "number"},
        "delta_P": {"type": "number", "exclusiveMinimum": 0},
        "full_collar_derivative_target": {"type": "number", "exclusiveMinimum": 0},
        "orientation_halves": {"const": 2},
        "theta": {"type": "number", "exclusiveMinimum": 0},
        "eta_R": {"type": "number", "exclusiveMinimum": 0},
        "n_s": {"type": "number"},
        "kappa_rep": {"type": "number", "exclusiveMinimum": 0},
        "kappa_rep_formula": {"type": "string"},
        "selected_theorem_target": {"const": true},
        "finite_lattice_derived": {"const": false},
        "diagnostic_controls": {"type": "object"}
      },
      "additionalProperties": false
    },
    "sourceDagAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clean",
        "node_count",
        "edge_count",
        "source_kinds",
        "binding_node_present",
        "binding_node_kind_valid",
        "binding_node_hash_matches",
        "binding_node_is_leaf",
        "root_source_reaches_binding",
        "all_nodes_ancestral_to_binding",
        "blockers"
      ],
      "properties": {
        "clean": {"type": "boolean"},
        "node_count": {"type": "integer", "minimum": 0},
        "edge_count": {"type": "integer", "minimum": 0},
        "source_kinds": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "binding_node_present": {"type": "boolean"},
        "binding_node_kind_valid": {"type": "boolean"},
        "binding_node_hash_matches": {"type": "boolean"},
        "binding_node_is_leaf": {"type": "boolean"},
        "root_source_reaches_binding": {"type": "boolean"},
        "all_nodes_ancestral_to_binding": {"type": "boolean"},
        "blockers": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "observed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_collar_derivative",
        "orientation_halves",
        "orientation_half_identity_defect",
        "semigroup_defect",
        "refinement_defect",
        "clock_binding_source",
        "clock_binding_sha256",
        "computed_clock_binding_sha256",
        "clock_binding_hash_matches",
        "source_dag_sha256",
        "computed_source_dag_sha256",
        "source_dag_hash_matches",
        "source_dag_audit",
        "pixel_provenance"
      ],
      "properties": {
        "full_collar_derivative": {"$ref": "#/$defs/nullableNumber"},
        "orientation_halves": {"$ref": "#/$defs/nullableInteger"},
        "orientation_half_identity_defect": {"$ref": "#/$defs/nullableDefect"},
        "semigroup_defect": {"$ref": "#/$defs/nullableDefect"},
        "refinement_defect": {"$ref": "#/$defs/nullableDefect"},
        "clock_binding_source": {"$ref": "#/$defs/nullableString"},
        "clock_binding_sha256": {"$ref": "#/$defs/nullableHash"},
        "computed_clock_binding_sha256": {"$ref": "#/$defs/nullableHash"},
        "clock_binding_hash_matches": {"type": "boolean"},
        "source_dag_sha256": {"$ref": "#/$defs/nullableHash"},
        "computed_source_dag_sha256": {"$ref": "#/$defs/nullableHash"},
        "source_dag_hash_matches": {"type": "boolean"},
        "source_dag_audit": {"$ref": "#/$defs/sourceDagAudit"},
        "pixel_provenance": {"type": "object"}
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_collar_derivative_equals_P_over_24",
        "orientation_half_identity",
        "semigroup_defect_bounded",
        "refinement_defect_bounded",
        "clock_binding_packet_consistency",
        "source_dag_clean_hash_bound",
        "generative_pixel_profile_bound",
        "independent_finite_run_replay"
      ],
      "properties": {
        "full_collar_derivative_equals_P_over_24": {"type": "boolean"},
        "orientation_half_identity": {"type": "boolean"},
        "semigroup_defect_bounded": {"type": "boolean"},
        "refinement_defect_bounded": {"type": "boolean"},
        "clock_binding_packet_consistency": {"type": "boolean"},
        "source_dag_clean_hash_bound": {"type": "boolean"},
        "generative_pixel_profile_bound": {"type": "boolean"},
        "independent_finite_run_replay": {"const": false}
      }
    },
    "receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "FULL_COLLAR_DERIVATIVE_P_OVER_24_RECEIPT",
        "ORIENTATION_HALF_IDENTITY_RECEIPT",
        "SEMIGROUP_DEFECT_RECEIPT",
        "REFINEMENT_DEFECT_RECEIPT",
        "PHYSICAL_CLOCK_BINDING_RECEIPT",
        "SOURCE_DAG_CLEAN_RECEIPT",
        "GENERATIVE_PIXEL_PROFILE_RECEIPT",
        "INDEPENDENT_FINITE_RUN_REPLAY_RECEIPT"
      ],
      "properties": {
        "FULL_COLLAR_DERIVATIVE_P_OVER_24_RECEIPT": {"type": "boolean"},
        "ORIENTATION_HALF_IDENTITY_RECEIPT": {"type": "boolean"},
        "SEMIGROUP_DEFECT_RECEIPT": {"type": "boolean"},
        "REFINEMENT_DEFECT_RECEIPT": {"type": "boolean"},
        "PHYSICAL_CLOCK_BINDING_RECEIPT": {"const": false},
        "SOURCE_DAG_CLEAN_RECEIPT": {"type": "boolean"},
        "GENERATIVE_PIXEL_PROFILE_RECEIPT": {"type": "boolean"},
        "INDEPENDENT_FINITE_RUN_REPLAY_RECEIPT": {"const": false}
      }
    }
  }
}
