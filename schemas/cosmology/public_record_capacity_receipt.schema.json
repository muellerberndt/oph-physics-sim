{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floatingpragma.io/schemas/public-record-capacity-v1.schema.json",
  "title": "OPH exact finite public-record capacity certificate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "packet_status",
    "regulator_id",
    "port_count",
    "interface_count",
    "public_global_section_count",
    "reachable_public_record_count",
    "checkpoint_generator_receipts",
    "exact_zero_error_capacity_M0",
    "readback_nats_log_M0",
    "capacity_dimension_D",
    "fast_branch_identity",
    "robust_terminal_saturation",
    "rank_one_complete",
    "REFERENCE_REVERSIBLE_PUBLIC_CHECKPOINT_RECEIPT",
    "PHYSICAL_N_CLOSURE_RECEIPT",
    "remaining_physical_obligations",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "oph-public-record-capacity-v1"},
    "status": {"const": "PASS"},
    "packet_status": {"const": "REFERENCE_CONTROL_NOT_PHYSICAL_RECEIPT"},
    "regulator_id": {"type": "string", "minLength": 1},
    "port_count": {"const": 12},
    "interface_count": {"const": 30},
    "public_global_section_count": {"type": "integer", "minimum": 1},
    "reachable_public_record_count": {"type": "integer", "minimum": 1},
    "checkpoint_generator_receipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "continuation_id",
          "deterministic",
          "injective",
          "permutation_of_reachable_records"
        ],
        "properties": {
          "continuation_id": {"type": "string", "minLength": 1},
          "deterministic": {"const": true},
          "injective": {"const": true},
          "permutation_of_reachable_records": {"const": true}
        }
      }
    },
    "exact_zero_error_capacity_M0": {"type": "integer", "minimum": 1},
    "readback_nats_log_M0": {"type": "number", "minimum": 0},
    "capacity_dimension_D": {"type": "integer", "minimum": 1},
    "fast_branch_identity": {"const": "M_0(q)=|X_reach(q)|"},
    "robust_terminal_saturation": {"type": "boolean"},
    "rank_one_complete": {"type": "boolean"},
    "REFERENCE_REVERSIBLE_PUBLIC_CHECKPOINT_RECEIPT": {"const": true},
    "PHYSICAL_N_CLOSURE_RECEIPT": {"const": false},
    "remaining_physical_obligations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "claim_boundary": {"type": "string", "minLength": 1}
  }
}
