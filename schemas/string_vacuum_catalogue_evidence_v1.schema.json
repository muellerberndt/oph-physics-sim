{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floatingpragma.io/schemas/string_vacuum_catalogue_evidence_v1.schema.json",
  "title": "OPH string-vacuum catalogue evidence packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact",
    "schema_version",
    "catalogue_id",
    "declared_scope",
    "provenance",
    "artifacts",
    "equivalence_partition",
    "candidate_reports",
    "unresolved_regions",
    "producer_classification"
  ],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "artifact": {"const": "oph_string_vacuum_catalogue_evidence"},
    "schema_version": {"const": 1},
    "catalogue_id": {"type": "string", "minLength": 1},
    "declared_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_statement",
        "catalogue_complete_within_scope",
        "enumeration_proof_artifact_id",
        "unrestricted_string_universe_covered",
        "reduction_theorem_artifact_id"
      ],
      "properties": {
        "scope_statement": {"type": "string", "minLength": 1},
        "catalogue_complete_within_scope": {"type": "boolean"},
        "enumeration_proof_artifact_id": {"type": ["string", "null"]},
        "unrestricted_string_universe_covered": {"type": "boolean"},
        "reduction_theorem_artifact_id": {"type": ["string", "null"]}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "producer_commit", "verifier_commit", "source_dirty", "replay_argv"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "producer_commit": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"},
        "verifier_commit": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"},
        "source_dirty": {"type": "boolean"},
        "replay_argv": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/artifactRow"}
    },
    "equivalence_partition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_definition_sha256",
        "partition_proof_artifact_id",
        "duality_families_covered"
      ],
      "properties": {
        "relation_definition_sha256": {"$ref": "#/$defs/sha256"},
        "partition_proof_artifact_id": {"type": ["string", "null"]},
        "duality_families_covered": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "candidate_reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "oph_equivalence_class_id",
          "evidence_packet_path",
          "evidence_packet_sha256",
          "verification_report_path",
          "verification_report_sha256",
          "branch_domain_coverage_status",
          "branch_domain_coverage_artifact_id",
          "branch_verdict_ledger_artifact_id",
          "producer_status_hint"
        ],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "oph_equivalence_class_id": {"type": "string", "minLength": 1},
          "evidence_packet_path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
          "evidence_packet_sha256": {"$ref": "#/$defs/sha256"},
          "verification_report_path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
          "verification_report_sha256": {"$ref": "#/$defs/sha256"},
          "branch_domain_coverage_status": {"enum": ["PASS", "FAIL", "INCONCLUSIVE"]},
          "branch_domain_coverage_artifact_id": {"type": ["string", "null"]},
          "branch_verdict_ledger_artifact_id": {"type": ["string", "null"]},
          "producer_status_hint": {"enum": ["PASS", "FAIL", "INCONCLUSIVE"]}
        }
      }
    },
    "unresolved_regions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "producer_classification": {"enum": ["CATALOGUE_COMPLETE", "INCOMPLETE"]}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "artifactRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "path", "sha256", "format", "semantic_role"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "format": {"enum": ["json", "text", "proof", "other"]},
        "semantic_role": {"type": "string", "minLength": 1}
      }
    }
  }
}
