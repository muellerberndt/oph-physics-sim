{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://floatingpragma.io/schemas/oph_universe_timeline_visualization_payload_v1.schema.json",
  "title": "OPH Universe Timeline Visualization Payload",
  "description": "Schema for OPH-FPE visualization payloads that show observer-like self-reading systems: bounded patches with local state, ports or boundaries, readback, records, feedback or repair moves, and public receipts. Diagnostic views must not be promoted to strict neutral bulk, matter particles, or physical CMB prediction unless the corresponding receipts are true.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "schema",
    "title",
    "claimBoundary",
    "ophDifferentiator",
    "sourcePaths",
    "smallUniverse",
    "screen",
    "subjectiveObserverCameras",
    "observerModularTime",
    "consensusBulk",
    "pnSilenceToObservation",
    "cmbComparison",
    "comparableObservations",
    "geometriesAndSymmetries",
    "visualizationViews",
    "effectiveStringTheory",
    "emergentCurvedSpacetime",
    "observerCinema",
    "hilbertSpaceObserverAlgebra",
    "observerAnatomy",
    "paperAccuracy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "oph_universe_timeline_visualization_payload_v1"
    },
    "schema": {
      "const": "oph_universe_timeline_visualization_payload_v1"
    },
    "title": {
      "type": "string"
    },
    "claimBoundary": {
      "type": "string"
    },
    "ophDifferentiator": {
      "type": "string"
    },
    "sourcePaths": {
      "$ref": "#/$defs/sourcePaths"
    },
    "smallUniverse": {
      "$ref": "#/$defs/smallUniverse"
    },
    "screen": {
      "$ref": "#/$defs/screen"
    },
    "subjectiveObserverCameras": {
      "type": "array",
      "description": "Observer-local rendering cameras derived from visible observer readouts. These are subjective readout cameras, not hidden global cameras.",
      "items": {
        "$ref": "#/$defs/subjectiveObserverCamera"
      }
    },
    "observerModularTime": {
      "$ref": "#/$defs/observerModularTime"
    },
    "consensusBulk": {
      "$ref": "#/$defs/consensusBulk"
    },
    "pnSilenceToObservation": {
      "$ref": "#/$defs/pnSilenceToObservation"
    },
    "cmbComparison": {
      "$ref": "#/$defs/cmbComparison"
    },
    "comparableObservations": {
      "$ref": "#/$defs/comparableObservations"
    },
    "geometriesAndSymmetries": {
      "type": "object",
      "description": "Human-readable explanations and receipt summaries for visible geometries and symmetries.",
      "additionalProperties": true
    },
    "visualizationViews": {
      "$ref": "#/$defs/visualizationViews"
    },
    "visualizationRenderData": {
      "$ref": "#/$defs/visualizationRenderData"
    },
    "effectiveStringTheory": {
      "$ref": "#/$defs/openObject"
    },
    "emergentCurvedSpacetime": {
      "$ref": "#/$defs/openObject"
    },
    "observerCinema": {
      "$ref": "#/$defs/openObject"
    },
    "hilbertSpaceObserverAlgebra": {
      "$ref": "#/$defs/openObject"
    },
    "observerAnatomy": {
      "$ref": "#/$defs/openObject"
    },
    "paperAccuracy": {
      "$ref": "#/$defs/openObject"
    }
  },
  "$defs": {
    "scalar": {
      "type": ["boolean", "integer", "number", "string", "null"]
    },
    "receiptMap": {
      "type": "object",
      "description": "Receipt entries are strict gates. Missing keys must be rendered as absent, never as passing.",
      "additionalProperties": {
        "$ref": "#/$defs/scalar"
      }
    },
    "openObject": {
      "type": "object",
      "additionalProperties": true
    },
    "visualizationRenderData": {
      "type": "object",
      "description": "Renderer-ready convenience data derived from the authoritative payload: availability counts, camera presets, scene graph, animation timeline, plot series, legends, and claim badges.",
      "additionalProperties": true,
      "required": [
        "schema",
        "availability",
        "rendererHints",
        "cameraPresets",
        "sceneGraph",
        "animationTimeline",
        "plotSeries",
        "legend",
        "claimBadges",
        "viewContracts",
        "claimBoundary"
      ],
      "properties": {
        "schema": {
          "const": "oph_visualization_render_data_v1"
        },
        "description": {
          "type": "string"
        },
        "availability": {
          "type": "object",
          "additionalProperties": {
            "type": ["integer", "number", "boolean", "string", "null"]
          }
        },
        "rendererHints": {
          "$ref": "#/$defs/openObject"
        },
        "cameraPresets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openObject"
          }
        },
        "repairPlayback": {
          "type": "object",
          "description": "Renderer timing policy for gradual repair animation. Use playbackRelativeTime for UI playback and rawRelativeTime/cycle for auditable simulation timing.",
          "additionalProperties": true
        },
        "sceneGraph": {
          "type": "object",
          "additionalProperties": true,
          "required": ["screen", "observerGraph", "bulk", "finiteRepairGraph"]
        },
        "animationTimeline": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openObject"
          }
        },
        "plotSeries": {
          "$ref": "#/$defs/openObject"
        },
        "legend": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openObject"
          }
        },
        "claimBadges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openObject"
          }
        },
        "viewContracts": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/openObject"
          }
        },
        "claimBoundary": {
          "type": "string"
        }
      }
    },
    "visualizationViews": {
      "type": "object",
      "description": "First-class view contracts for web visualizers. These views name the intended panels and the payload fields that support them without promoting closed receipts.",
      "additionalProperties": {
        "$ref": "#/$defs/visualizationView"
      },
      "required": [
        "fluctuatingQuantumVacuum",
        "observerCamera",
        "emergentCurvedSpacetime",
        "effectiveStringTheory"
      ],
      "properties": {
        "fluctuatingQuantumVacuum": {
          "$ref": "#/$defs/visualizationView"
        },
        "observerCamera": {
          "$ref": "#/$defs/visualizationView"
        },
        "emergentCurvedSpacetime": {
          "$ref": "#/$defs/visualizationView"
        },
        "effectiveStringTheory": {
          "$ref": "#/$defs/visualizationView"
        },
        "fractionalQuotientSectors": {
          "$ref": "#/$defs/visualizationView"
        },
        "silenceToObservation": {
          "$ref": "#/$defs/visualizationView"
        }
      }
    },
    "visualizationView": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "viewId",
        "sectionKind",
        "label",
        "visualMetaphor",
        "description",
        "dataSources",
        "primaryFields",
        "renderLayers",
        "visualEncodings",
        "animationChannels",
        "receipts",
        "exportSufficiency",
        "promotionReceiptsRequired",
        "nonClaims",
        "claimBoundary"
      ],
      "properties": {
        "viewId": {
          "type": "string"
        },
        "sectionKind": {
          "type": "string",
          "description": "Stable machine-readable section type for custom visualizers."
        },
        "label": {
          "type": "string"
        },
        "visualMetaphor": {
          "type": "string",
          "description": "Short visual intent, not a physical claim."
        },
        "description": {
          "type": "string"
        },
        "dataSources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primaryFields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "renderLayers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/renderLayer"
          }
        },
        "visualEncodings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/visualEncoding"
          }
        },
        "animationChannels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/animationChannel"
          }
        },
        "receipts": {
          "$ref": "#/$defs/receiptMap"
        },
        "exportSufficiency": {
          "type": "string"
        },
        "promotionReceiptsRequired": {
          "type": "array",
          "description": "Receipt names that would be required before upgrading this view from diagnostic rendering to the corresponding physical claim.",
          "items": {
            "type": "string"
          }
        },
        "nonClaims": {
          "type": "array",
          "description": "Labels the visualizer must avoid unless future receipts explicitly pass.",
          "items": {
            "type": "string"
          }
        },
        "claimBoundary": {
          "type": ["string", "null"]
        }
      }
    },
    "renderLayer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["layer", "source"],
      "properties": {
        "layer": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "visualEncoding": {
      "type": "object",
      "additionalProperties": true,
      "required": ["field", "source", "encoding"],
      "properties": {
        "field": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "encoding": {
          "type": "string"
        },
        "palette": {
          "type": ["string", "null"]
        }
      }
    },
    "animationChannel": {
      "type": "object",
      "additionalProperties": true,
      "required": ["channel", "source", "encoding"],
      "properties": {
        "channel": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "timeSource": {
          "type": ["string", "null"]
        },
        "encoding": {
          "type": "string"
        }
      }
    },
    "vec3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "number"
      }
    },
    "sourcePaths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "smallUniverseDir",
        "observerRunDir",
        "consensusPackDir",
        "consensusReadoutDir"
      ],
      "properties": {
        "smallUniverseDir": {
          "type": "string"
        },
        "observerRunDir": {
          "type": "string"
        },
        "consensusPackDir": {
          "type": ["string", "null"]
        },
        "consensusReadoutDir": {
          "type": ["string", "null"]
        }
      }
    },
    "smallUniverse": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "description",
        "source",
        "nodeCount",
        "nodes",
        "edges",
        "repairFrames",
        "cycles",
        "receipts",
        "claimBoundary"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "nodeCount": {
          "type": "integer",
          "minimum": 0
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/smallUniverseNode"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edge"
          }
        },
        "repairFrames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repairFrame"
          }
        },
        "cycles": {
          "type": "object",
          "additionalProperties": true,
          "required": ["exactConsensus", "frustratedControl"],
          "properties": {
            "exactConsensus": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/openObject"
              }
            },
            "frustratedControl": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/openObject"
              }
            }
          }
        },
        "receipts": {
          "$ref": "#/$defs/receiptMap"
        },
        "claimBoundary": {
          "type": "string"
        }
      }
    },
    "smallUniverseNode": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "position"],
      "properties": {
        "id": {
          "type": "integer"
        },
        "position": {
          "$ref": "#/$defs/vec3"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "target"],
      "properties": {
        "source": {
          "type": "integer"
        },
        "target": {
          "type": "integer"
        }
      }
    },
    "repairFrame": {
      "type": "object",
      "additionalProperties": true,
      "required": ["step", "stateId", "state", "phi", "action", "parent", "node", "deltaPhi"],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 0
        },
        "stateId": {
          "type": "string"
        },
        "state": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scalar"
          }
        },
        "phi": {
          "type": ["number", "null"]
        },
        "phiBefore": {
          "type": ["number", "null"]
        },
        "action": {
          "type": "string"
        },
        "parent": {
          "type": ["integer", "null"]
        },
        "node": {
          "type": ["integer", "null"]
        },
        "deltaPhi": {
          "type": ["number", "null"]
        },
        "strictDescent": {
          "type": "boolean"
        }
      }
    },
    "screen": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "description",
        "source",
        "fieldName",
        "points",
        "values",
        "clusters",
        "repairTrace",
        "claimBoundary"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "fieldName": {
          "type": "string"
        },
        "points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vec3"
          }
        },
        "values": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "clusters": {
          "$ref": "#/$defs/screenClusters"
        },
        "repairTrace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repairTraceFrame"
          }
        },
        "claimBoundary": {
          "type": "string"
        }
      }
    },
    "screenClusters": {
      "type": "object",
      "additionalProperties": true,
      "required": ["clusters", "snapshots", "rawSnapshotCount", "snapshotSource", "persistentWorldlineCount"],
      "properties": {
        "clusters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/screenCluster"
          }
        },
        "snapshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/screenClusterSnapshot"
          }
        },
        "rawSnapshotCount": {
          "type": "integer",
          "minimum": 0
        },
        "snapshotSource": {
          "type": "string"
        },
        "persistentWorldlineCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "screenCluster": {
      "type": "object",
      "additionalProperties": true,
      "required": ["clusterId", "point"],
      "properties": {
        "clusterId": {
          "type": ["integer", "string", "null"]
        },
        "worldlineId": {
          "type": ["integer", "string", "null"]
        },
        "point": {
          "$ref": "#/$defs/vec3"
        },
        "class": {
          "type": ["string", "null"]
        },
        "supportNodeCount": {
          "type": ["integer", "number", "null"]
        }
      }
    },
    "screenClusterSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "required": ["cycle", "clusterCount", "clusters", "snapshotSource"],
      "properties": {
        "cycle": {
          "type": ["integer", "number", "null"]
        },
        "clusterCount": {
          "type": ["integer", "number", "null"]
        },
        "clusters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/screenCluster"
          }
        },
        "snapshotSource": {
          "type": "string"
        },
        "interpolated": {
          "type": "boolean"
        }
      }
    },
    "repairTraceFrame": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cycle": {
          "type": ["integer", "number", "null"]
        },
        "phase": {
          "type": ["string", "null"]
        },
        "phi": {
          "type": ["integer", "number", "null"]
        },
        "committed_fraction": {
          "type": ["integer", "number", "null"]
        },
        "modular_depth_mean": {
          "type": ["integer", "number", "null"]
        },
        "mismatch_edges": {
          "type": ["integer", "number", "null"]
        }
      }
    },
    "observerModularTime": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "description",
        "source",
        "observers",
        "objectiveObserverViews",
        "overlapLinks",
        "overlapSummary",
        "timeFrames",
        "receipts",
        "blockers",
        "claimBoundary"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "observers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observerRow"
          }
        },
        "objectiveObserverViews": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectiveObserverView"
          }
        },
        "overlapLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observerOverlapLink"
          }
        },
        "overlapSummary": {
          "type": "object",
          "additionalProperties": true
        },
        "timeFrames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modularTimeFrame"
          }
        },
        "receipts": {
          "$ref": "#/$defs/receiptMap"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claimBoundary": {
          "type": "string"
        }
      }
    },
    "subjectiveObserverCamera": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "cameraId",
        "observerId",
        "kind",
        "eye",
        "lookAt",
        "up",
        "right",
        "forward",
        "fovDegrees",
        "screenProjection",
        "timeFrames",
        "claimBoundary"
      ],
      "properties": {
        "cameraId": {
          "type": "string"
        },
        "observerId": {
          "$ref": "#/$defs/scalar"
        },
        "kind": {
          "const": "observer_local_subjective_camera"
        },
        "eye": {
          "$ref": "#/$defs/vec3"
        },
        "lookAt": {
          "$ref": "#/$defs/vec3"
        },
        "up": {
          "$ref": "#/$defs/vec3"
        },
        "right": {
          "$ref": "#/$defs/vec3"
        },
        "forward": {
          "$ref": "#/$defs/vec3"
        },
        "fovDegrees": {
          "type": "number"
        },
        "screenProjection": {
          "type": "string"
        },
        "supportPatchCount": {
          "type": ["integer", "number", "null"]
        },
        "supportNodeSample": {
          "type": "array",
          "items": {
            "type": ["integer", "number"]
          }
        },
        "visibleObjectPackets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packetWeight"
          }
        },
        "visibleRecordPackets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packetWeight"
          }
        },
        "timeFrames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectiveObserverFrame"
          }
        },
        "claimBoundary": {
          "type": "string"
        }
      }
    },
    "observerRow": {
      "type": "object",
      "additionalProperties": true,
      "required": ["observerId", "axis"],
      "properties": {
        "observerId": {
          "type": ["integer", "number", "string", "null"]
        },
        "axis": {
          "$ref": "#/$defs/vec3"
        },
        "supportPatchCount": {
          "type": ["integer", "number", "null"]
        },
        "visibleSignatureEntropy": {
          "type": ["number", "null"]
        },
        "modularDepthMean": {
          "type": ["number", "null"]
        },
        "dominantRecordSignature": {
          "$ref": "#/$defs/scalar"
        },
        "dominantObjectPacket": {
          "$ref": "#/$defs/scalar"
        },
        "visibleReadoutHash": {
          "type": ["string", "null"]
        },
        "claimBoundary": {
          "type": ["string", "null"]
        }
      }
    },
    "objectiveObserverView": {
      "type": "object",
      "additionalProperties": true,
      "required": ["observerId", "axis", "timeFrames", "claimBoundary"],
      "properties": {
        "observerId": {
          "type": "integer"
        },
        "axis": {
          "$ref": "#/$defs/vec3"
        },
        "supportPatchCount": {
          "type": ["integer", "number", "null"]
        },
        "supportNodeSample": {
          "type": "array",
          "items": {
            "type": ["integer", "number"]
          }
        },
        "supportEntropyCapacity": {
          "type": ["number", "null"]
        },
        "visibleObjectPackets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packetWeight"
          }
        },
        "visibleRecordPackets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packetWeight"
          }
        },
        "transitionHistory": {
          "type": "object",
          "additionalProperties": true
        },
        "timeFrames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/objectiveObserverFrame"
          }
        },
        "claimBoundary": {
          "type": "string"
        }
      }
    },
    "packetWeight": {
      "type": "object",
      "additionalProperties": true,
      "required": ["packet", "weight"],
      "properties": {
        "packet": {
          "type": ["string", "integer", "number"]
        },
        "weight": {
          "type": "number"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "objectiveObserverFrame": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "relativeTime",
        "cycle",
        "visibleObjectPackets",
        "visibleRecordPackets",
        "polarFieldReadout",
        "framePacketSource"
      ],
      "properties": {
        "relativeTime": {
          "type": ["number", "null"]
        },
        "cycle": {
          "type": ["integer", "number", "null"]
        },
        "phase": {
          "type": ["string", "null"]
        },
        "globalPhi": {
          "type": ["number", "null"]
        },
        "globalCommittedFraction": {
          "type": ["number", "null"]
        },
        "localTransitionStep": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "dominantRecordSignature": {
          "$ref": "#/$defs/scalar"
        },
        "dominantObjectPacket": {
          "$ref": "#/$defs/scalar"
