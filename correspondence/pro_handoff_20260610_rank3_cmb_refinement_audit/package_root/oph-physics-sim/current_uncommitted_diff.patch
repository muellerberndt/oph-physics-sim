+        and np.isfinite(h4_stress)
+        and selected_stress <= h4_stress + _model_compatibility_tolerance(h4_stress)
+    )
+    return bool(
+        dimension.get("estimators_agree_3d", False)
+        and h3_or_e3
+        and leakage.get("s2_leakage_pass", False)
+        and h4_compatible
