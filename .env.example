# Local-only cloud defaults for OPH physics simulation.
# Copy to .env.local or export these in your shell.
# Do not commit real project IDs, bucket names, account IDs, tokens, keys, or secrets.

GCP_PROJECT_ID=your-gcp-project-id
GCP_PROJECT_NUMBER=000000000000
GCP_REGION=your-gcp-region
GCP_ZONE=your-gcp-zone
GCP_ARTIFACT_BUCKET=your-gcs-artifact-bucket

AWS_PROFILE=your-aws-profile
AWS_REGION=your-aws-region
