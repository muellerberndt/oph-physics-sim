.DS_Store
__pycache__/
.pytest_cache/

# Local secrets and machine-specific cloud settings.
.env
.env.*
!.env.example
*.tfvars
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
credentials/
secrets/

# Local correspondence and handoff scratch space.
correspondence/

# Local/generated run configs. Curated examples stay tracked under configs/.
configs/local/
configs/generated/
configs/*.local.yml
configs/*.local.yaml
configs/*.local.toml
configs/*.private.yml
configs/*.private.yaml
configs/*.private.toml
configs/*.tmp.yml
configs/*.tmp.yaml
configs/*.tmp.toml

# Generated artifacts.
artifacts/
receipts/
runs/
distributed/
temp/
.oph_fpe_cache/
*.log
*.jsonl

# Empirical run outputs are retained locally or in receipt archives, not in Git.
data/earned_runs/
